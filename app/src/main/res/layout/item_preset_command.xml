<?xml version="1.0" encoding="utf-8"?>
<!--
  Preset-command chip for the ADB console. Monospace because these
  are literal shell commands; M3 surface-tier alternation provides the
  card-like feel without a 1dp stroke.
-->
<com.google.android.material.chip.Chip xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chipPreset"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:clickable="true"
    android:focusable="true"
    android:fontFamily="monospace"
    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
    android:textColor="?attr/colorOnSurface"
    app:chipBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:chipCornerRadius="@dimen/card_radius_accent"
    app:chipStrokeColor="?attr/colorOutline"
    app:chipStrokeWidth="0dp" />
