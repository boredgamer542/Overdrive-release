<?xml version="1.0" encoding="utf-8"?>
<!--
  Bottom sheet hosting the actor + severity filter chip rows extracted from
  fragment_recording_library.xml. Same chip IDs preserved exactly so existing
  Kotlin findViewById and click logic in RecordingLibraryFragment continue to
  work unchanged: chipActorAny / Person / Vehicle / Bike / Animal,
  chipSevAny / Alert / Critical, and the actorChipGroup / severityChipGroup
  containers.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="8dp"
    android:paddingBottom="20dp">

    <!-- Drag handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/recording_lib_count_pill"
        android:alpha="0.5" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/recording_lib_filter_sheet_title"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterReset"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/recording_lib_filter_reset"
            android:textSize="13sp"
            android:minHeight="36dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

    <!-- WHAT (actor class) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/recording_lib_filter_section_what"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:paddingTop="4dp"
        android:paddingBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/actorChipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingHorizontal="6dp"
        app:chipSpacingVertical="6dp"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipActorAny"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_chip_any"
            android:checked="true" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipActorPerson"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_chip_person" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipActorVehicle"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_chip_vehicle" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipActorBike"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_chip_bike" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipActorAnimal"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_chip_animal" />
    </com.google.android.material.chip.ChipGroup>

    <!-- SEVERITY -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/recording_lib_filter_section_severity"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:paddingTop="20dp"
        android:paddingBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/severityChipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingHorizontal="6dp"
        app:chipSpacingVertical="6dp"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSevAny"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_chip_any"
            android:checked="true" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipSevAlert"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_chip_alert" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipSevCritical"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording_lib_chip_critical" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Apply button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFilterApply"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:text="@string/recording_lib_filter_apply"
        android:textSize="14sp"
        app:cornerRadius="24dp" />

</LinearLayout>
