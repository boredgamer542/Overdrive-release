<?xml version="1.0" encoding="utf-8"?>
<!--
  SOTA Dashboard.

  Composition (top to bottom):
   1. Hero — large greeting + subtitle, brand-tinted gradient surface.
   2. Metric grid — 2×2 of big-number tiles (Recordings · Storage · Remote · Services).
   3. Connect card — QR + tunnel chip group + access code (collapsed by default).
   4. Quick action chips row.

  Single ScrollView; uses ?attr/colorSurfaceContainer* tiers for layered depth
  without elevation shadows. All colors via M3 attrs so light/dark flips cleanly.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/page_padding_bottom">

        <!-- ================== HERO ================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/heroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_gap_vertical"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardCornerRadius="@dimen/card_radius_hero"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding_hero">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/heroGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_greeting_morning"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/heroSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/dashboard_subtitle_all_systems"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:alpha="0.78" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/card_icon_hero"
                    android:layout_height="@dimen/card_icon_hero"
                    android:contentDescription="@string/cd_brand_logo"
                    android:src="@drawable/ic_sidebar_logo"
                    app:tint="?attr/colorOnPrimaryContainer"
                    android:alpha="0.65" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ================== METRIC GRID 2×2 ================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/card_gap_vertical"
            android:baselineAligned="false">

            <!-- Recordings tile -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/metricRecordings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/card_gap_horizontal_half"
                android:minHeight="@dimen/grid_tile_min_height"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="@dimen/card_radius_standard"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_standard">

                    <ImageView
                        android:layout_width="@dimen/card_icon_standard"
                        android:layout_height="@dimen/card_icon_standard"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_recording"
                        app:tint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/metricRecordingsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/dashboard_metric_value_pending"
                        android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/dashboard_metric_recordings"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Storage tile -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/metricStorage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/card_gap_horizontal_half"
                android:minHeight="@dimen/grid_tile_min_height"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="@dimen/card_radius_standard"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_standard">

                    <ImageView
                        android:layout_width="@dimen/card_icon_standard"
                        android:layout_height="@dimen/card_icon_standard"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_dashboard"
                        app:tint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/metricStorageValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/dashboard_metric_value_pending"
                        android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/dashboard_metric_storage"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/card_gap_vertical"
            android:baselineAligned="false">

            <!-- Remote access tile -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/metricTunnel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/card_gap_horizontal_half"
                android:minHeight="@dimen/grid_tile_min_height"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="@dimen/card_radius_standard"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_standard">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="@dimen/card_icon_standard"
                            android:layout_height="@dimen/card_icon_standard"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_dashboard"
                            app:tint="?attr/colorPrimary" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <View
                            android:id="@+id/tunnelStateDot"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/status_dot_offline" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/metricTunnelValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/dashboard_tunnel_offline"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/dashboard_metric_tunnel"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Background services tile -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDaemons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/card_gap_horizontal_half"
                android:minHeight="@dimen/grid_tile_min_height"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="@dimen/card_radius_standard"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_standard">

                    <ImageView
                        android:layout_width="@dimen/card_icon_standard"
                        android:layout_height="@dimen/card_icon_standard"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_daemons"
                        app:tint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/tvDaemonsStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/dashboard_daemons_running_default"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/dashboard_metric_services"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ================== CONNECT CARD ================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_gap_vertical"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius_hero"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_hero">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dashboard_scan_to_connect"
                        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tvDeviceId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="@string/dashboard_device_id_loading"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textIsSelectable="true" />
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupTunnels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/colorSurfaceContainerLowest"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/ivQrCode"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:background="@android:color/white"
                            android:contentDescription="@string/cd_qr_code"
                            android:padding="8dp"
                            android:scaleType="fitCenter" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvQrPlaceholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/dashboard_qr_waiting"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tvUrl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:ellipsize="middle"
                        android:fontFamily="monospace"
                        android:maxWidth="320dp"
                        android:singleLine="true"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorPrimary"
                        android:textIsSelectable="true"
                        android:visibility="gone" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="?attr/colorOutlineVariant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/dashboard_access_code"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurfaceContainerLow"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvDeviceToken"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.18"
                        android:singleLine="true"
                        android:text="@string/dashboard_token_masked"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <ImageView
                        android:id="@+id/btnToggleToken"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_show_hide_token"
                        android:padding="6dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <ImageView
                        android:id="@+id/btnCopyToken"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_copy_token"
                        android:padding="6dp"
                        android:src="@drawable/ic_copy"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegenerateToken"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:layout_gravity="end"
                    android:text="@string/dashboard_regenerate_token"
                    android:textAllCaps="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ================== QUICK ACTIONS ================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickLive"
                style="@style/Widget.Material3.Button.TonalButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:text="@string/dashboard_action_live"
                android:textAllCaps="false"
                app:icon="@drawable/ic_dashboard"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cardRecording"
                style="@style/Widget.Material3.Button.TonalButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:text="@string/dashboard_action_recordings"
                android:textAllCaps="false"
                app:icon="@drawable/ic_recording"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickSettings"
                style="@style/Widget.Material3.Button.TonalButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/dashboard_action_settings"
                android:textAllCaps="false"
                app:icon="@drawable/ic_settings"
                app:iconGravity="textStart" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
