<?xml version="1.0" encoding="utf-8"?>
<!--
  Theme preview — Light surface tier (top half of the Light preview).

  Static light-mode background. We deliberately don't use ?attr tokens
  here because this swatch should always read as "light mode" regardless
  of the user's current theme.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFF8F8FB" />
    <corners
        android:topLeftRadius="12dp"
        android:topRightRadius="12dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />
</shape>
