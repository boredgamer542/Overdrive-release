<?xml version="1.0" encoding="utf-8"?>
<!--
  SOTA daemon card.

  M3 surface-tier alternation (no stroke). The expandable subprocess block
  uses ?attr/colorSurfaceContainerHigh so it reads as a tonally distinct
  drawer below the main row.

  IDs preserved (DaemonAdapter.kt findViewById targets):
    mainRow, statusIndicator, tvDaemonName, tvDaemonStatus,
    ivExpand, ivConfigure, ivDownloadLog, switchDaemon,
    subprocessContainer, subprocessList.
  REMOVED: statusGlow (M3 doesn't use glow effects).
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginBottom="@dimen/card_gap_vertical"
    app:cardBackgroundColor="?attr/colorSurfaceContainer"
    app:cardCornerRadius="@dimen/card_radius_standard"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main Row -->
        <LinearLayout
            android:id="@+id/mainRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding_standard">

            <!-- Status Indicator dot -->
            <View
                android:id="@+id/statusIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/status_indicator" />

            <!-- Daemon Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDaemonName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/daemon_card_default_name"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tvDaemonStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/daemon_card_default_status"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- Expand indicator (only visible when has subprocesses) -->
            <ImageView
                android:id="@+id/ivExpand"
                android:layout_width="@dimen/card_icon_standard"
                android:layout_height="@dimen/card_icon_standard"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_expand"
                android:visibility="gone"
                app:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@string/cd_expand" />

            <!-- Configure button (only visible for configurable daemons like Zrok) -->
            <ImageView
                android:id="@+id/ivConfigure"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:padding="4dp"
                android:src="@drawable/ic_settings"
                android:visibility="gone"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@string/cd_configure" />

            <!-- Download log button (only visible in debug builds) -->
            <ImageView
                android:id="@+id/ivDownloadLog"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:padding="4dp"
                android:src="@drawable/ic_download_log"
                android:visibility="gone"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@string/cd_download_log" />

            <!-- Toggle Switch -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDaemon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Expandable Subprocess Section -->
        <LinearLayout
            android:id="@+id/subprocessContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingHorizontal="@dimen/card_padding_standard"
            android:paddingTop="@dimen/card_gap_vertical"
            android:paddingBottom="@dimen/card_padding_standard"
            android:background="?attr/colorSurfaceContainerHigh">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/daemon_card_subprocesses"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textAllCaps="true"
                android:letterSpacing="0.06"
                android:layout_marginBottom="8dp" />

            <!-- Subprocess list will be added dynamically -->
            <LinearLayout
                android:id="@+id/subprocessList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
