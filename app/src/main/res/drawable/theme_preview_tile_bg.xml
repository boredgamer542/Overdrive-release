<?xml version="1.0" encoding="utf-8"?>
<!--
  Theme preview tile background — outer container of one Auto/Light/Dark tile.

  States:
    - selected: 2dp colorPrimary stroke, colorSurfaceContainerHigh fill (active)
    - pressed:  colorSurfaceContainerHigh fill (touch feedback)
    - default:  1dp colorOutlineVariant stroke, colorSurfaceContainer fill

  Corner radius 18dp matches the M3 large-rounding pattern used elsewhere.
  All colors are ?attr tokens so light/dark mode flips automatically.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorSurfaceContainerHigh" />
            <stroke
                android:width="2dp"
                android:color="?attr/colorPrimary" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorSurfaceContainerHigh" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorOutlineVariant" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorSurfaceContainer" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorOutlineVariant" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
