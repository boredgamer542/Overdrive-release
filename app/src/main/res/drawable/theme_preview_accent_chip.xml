<?xml version="1.0" encoding="utf-8"?>
<!--
  Theme preview — small "primary accent" chip drawn over the surface tiles.
  Colored with ?attr/colorPrimary so it matches whatever palette the user
  is currently running. Rounded pill shape.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorPrimary" />
    <corners android:radius="999dp" />
</shape>
