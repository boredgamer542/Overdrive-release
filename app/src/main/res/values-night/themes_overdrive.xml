<?xml version="1.0" encoding="utf-8"?>
<!--
  Material 3 themes for Overdrive — DARK variant.
  Activated automatically when the system or AppCompatDelegate sets night mode.
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Overdrive.M3" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/md_sys_color_primary_dark</item>
        <item name="colorOnPrimary">@color/md_sys_color_on_primary_dark</item>
        <item name="colorPrimaryContainer">@color/md_sys_color_primary_container_dark</item>
        <item name="colorOnPrimaryContainer">@color/md_sys_color_on_primary_container_dark</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/md_sys_color_secondary_dark</item>
        <item name="colorOnSecondary">@color/md_sys_color_on_secondary_dark</item>
        <item name="colorSecondaryContainer">@color/md_sys_color_secondary_container_dark</item>
        <item name="colorOnSecondaryContainer">@color/md_sys_color_on_secondary_container_dark</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/md_sys_color_tertiary_dark</item>
        <item name="colorOnTertiary">@color/md_sys_color_on_tertiary_dark</item>
        <item name="colorTertiaryContainer">@color/md_sys_color_tertiary_container_dark</item>
        <item name="colorOnTertiaryContainer">@color/md_sys_color_on_tertiary_container_dark</item>

        <!-- Error -->
        <item name="colorError">@color/md_sys_color_error_dark</item>
        <item name="colorOnError">@color/md_sys_color_on_error_dark</item>
        <item name="colorErrorContainer">@color/md_sys_color_error_container_dark</item>
        <item name="colorOnErrorContainer">@color/md_sys_color_on_error_container_dark</item>

        <!-- Background / surface -->
        <item name="android:colorBackground">@color/md_sys_color_background_dark</item>
        <item name="colorOnBackground">@color/md_sys_color_on_background_dark</item>
        <item name="colorSurface">@color/md_sys_color_surface_dark</item>
        <item name="colorOnSurface">@color/md_sys_color_on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/md_sys_color_surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/md_sys_color_on_surface_variant_dark</item>
        <item name="colorSurfaceDim">@color/md_sys_color_surface_dim_dark</item>
        <item name="colorSurfaceBright">@color/md_sys_color_surface_bright_dark</item>
        <item name="colorSurfaceContainerLowest">@color/md_sys_color_surface_container_lowest_dark</item>
        <item name="colorSurfaceContainerLow">@color/md_sys_color_surface_container_low_dark</item>
        <item name="colorSurfaceContainer">@color/md_sys_color_surface_container_dark</item>
        <item name="colorSurfaceContainerHigh">@color/md_sys_color_surface_container_high_dark</item>
        <item name="colorSurfaceContainerHighest">@color/md_sys_color_surface_container_highest_dark</item>

        <!-- Outline -->
        <item name="colorOutline">@color/md_sys_color_outline_dark</item>
        <item name="colorOutlineVariant">@color/md_sys_color_outline_variant_dark</item>

        <!-- Inverse / scrim -->
        <item name="colorSurfaceInverse">@color/md_sys_color_inverse_surface_dark</item>
        <item name="colorOnSurfaceInverse">@color/md_sys_color_inverse_on_surface_dark</item>
        <item name="colorPrimaryInverse">@color/md_sys_color_inverse_primary_dark</item>
        <item name="scrimBackground">@color/md_sys_color_scrim_dark</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/md_sys_color_surface_container_dark</item>
        <item name="android:navigationBarColor">@color/md_sys_color_surface_container_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowBackground">@color/md_sys_color_background_dark</item>

        <!-- Text colors driven by M3 roles -->
        <item name="android:textColorPrimary">@color/md_sys_color_on_surface_dark</item>
        <item name="android:textColorSecondary">@color/md_sys_color_on_surface_variant_dark</item>
        <item name="android:textColorHint">@color/md_sys_color_outline_dark</item>

        <!-- Inherited component styles -->
        <item name="materialCardViewStyle">@style/Widget.Overdrive.M3.CardView</item>
        <item name="materialButtonStyle">@style/Widget.Overdrive.M3.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Overdrive.M3.Button.Outlined</item>
        <item name="toolbarStyle">@style/Widget.Overdrive.M3.Toolbar</item>
        <item name="sliderStyle">@style/Widget.Overdrive.M3.Slider</item>
        <item name="bottomSheetDialogTheme">@style/Theme.Overdrive.M3.BottomSheet</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Overdrive.M3.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.Overdrive.M3.MaterialAlertDialog</item>
    </style>

</resources>
