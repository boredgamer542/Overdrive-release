<?xml version="1.0" encoding="utf-8"?>
<!--
  LIGHT palette — used in light mode (default outside values-night/).
  Same keys as values-night/colors.xml so layouts that hard-code
  @color/bg_base, @color/text_primary, etc. flip automatically when
  the user toggles theme.

  Brand teal stays the same in both themes for identity continuity.
-->
<resources>
    <!-- Legacy compat colors -->
    <color name="white">#FFFFFFFF</color>

    <!-- Brand (slightly deeper for AA contrast on light surfaces) -->
    <color name="brand_primary">#00876C</color>
    <color name="brand_secondary">#00658F</color>
    <color name="brand_cyan">@color/brand_primary</color>
    <color name="brand_cyan_glow">#3300876C</color>

    <!-- Backgrounds — M3 light surface stack -->
    <color name="bg_base">#F7FAF7</color>
    <color name="bg_surface">#ECEFEC</color>
    <color name="bg_elevated">#E6E9E6</color>
    <color name="bg_hover">#E0E4E1</color>

    <color name="surface_variant">@color/bg_elevated</color>

    <!-- Text — dark on light -->
    <color name="text_primary">#181C1A</color>
    <color name="text_secondary">#3F4944</color>
    <color name="text_muted">#6F7975</color>

    <!-- Borders -->
    <color name="border_default">#26000000</color>

    <!-- Status — AA on light surfaces -->
    <color name="status_success">#1F7A3F</color>
    <color name="status_warning">#A6601C</color>
    <color name="status_danger">#BA1A1A</color>
    <color name="status_running">@color/status_success</color>
    <color name="status_stopped">@color/text_muted</color>
    <color name="status_error">@color/status_danger</color>
    <color name="status_starting">@color/status_warning</color>

    <!-- Accent legacy -->
    <color name="accent_orange">@color/status_warning</color>


    <!-- Logs -->

    <!-- Cards -->
    <color name="card_border">#1A000000</color>


    <!-- Switches -->
    <color name="switch_track_on">@color/brand_primary</color>
    <color name="switch_thumb_on">@color/white</color>
    <color name="switch_track_off">@color/bg_hover</color>
    <color name="switch_thumb_off">@color/text_muted</color>

    <!-- Buttons -->

    <!-- Gradient -->
</resources>
