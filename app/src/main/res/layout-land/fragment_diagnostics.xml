<?xml version="1.0" encoding="utf-8"?>
<!--
  SOTA Diagnostics dashboard — landscape (1920×1080 / ~960dp × 540dp).

  Composition (top→bottom, left→right):
    HERO ROW            : "System diagnostics" + descriptor (left) ║ status pill "All clear" (right)
    BODY ROW (weight=1) :
      LEFT COLUMN  (~400dp / weight 0.46):
        - HEALTH section (label-medium "Health")
        - 2×2 health-tile grid (Network, Storage, Camera, Battery)
        - TOOLS section (label-medium "Tools")
        - 2×2 tool grid (ADB, Traffic, Camera probe, Battery health) — outlined cards
      RIGHT COLUMN (~480dp / weight 0.54):
        - "Live event log" container card hosting LogsPanelFragment

  Math (1920px / 540dp content area – allowing for nav rail/drawer space):
    Body row content height ≈ 540dp − ~80dp hero − padding ⇒ ~420dp for the
    grids and the logs panel. Logs card uses match_parent against the body
    row so it always fills the right column.

  IDs preserved (DiagnosticsFragment.kt findViewById targets):
    cardAdb, cardTraffic, cardCameraProbe, cardBattery, logsPanelContainer

  Health-tile IDs (DiagnosticsFragment.kt findViewById targets):
    Network : tvNetworkValue / viewNetworkTunnelDot / tvNetworkTunnelState
    Storage : tvStorageUsed / tvStorageFree
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/page_padding_horizontal"
    android:paddingTop="@dimen/page_padding_top"
    android:paddingBottom="@dimen/page_padding_bottom"
    android:clipToPadding="false">

    <!-- ================== HERO ROW ================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/page_padding_top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/diagnostics_hero_title"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/diagnostics_hero_subtitle"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <!-- Health status pill — TODO: drive from real overall-health signal. -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSecondaryContainer"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot_online" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/diagnostics_health_clear"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="?attr/colorOnSecondaryContainer" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ================== BODY ROW (left grids ║ right logs panel) ================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- ===== LEFT COLUMN ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.46"
            android:layout_marginEnd="@dimen/card_gap_vertical"
            android:orientation="vertical">

            <!-- HEALTH section header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_overline_bottom"
                android:letterSpacing="0.06"
                android:text="@string/diagnostics_health_section"
                android:textAllCaps="true"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- HEALTH 2×2 GRID — row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Network tile -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/card_gap_horizontal_half"
                    android:minHeight="@dimen/grid_tile_min_height"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer"
                    app:cardCornerRadius="@dimen/card_radius_standard"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding_standard">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/card_icon_standard"
                                android:layout_height="@dimen/card_icon_standard"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_traffic_monitor"
                                app:tint="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:letterSpacing="0.06"
                            android:text="@string/diagnostics_health_network"
                            android:textAllCaps="true"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <!-- Top line: SSID / Mobile / Ethernet / Offline. Bound at runtime. -->
                        <TextView
                            android:id="@+id/tvNetworkValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/diagnostics_metric_online"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                        <!-- Bottom line: tunnel dot + state. Bound at runtime. -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/viewNetworkTunnelDot"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/status_dot_offline" />

                            <TextView
                                android:id="@+id/tvNetworkTunnelState"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/diagnostics_tunnel_state_offline"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Storage tile -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/card_gap_horizontal_half"
                    android:minHeight="@dimen/grid_tile_min_height"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer"
                    app:cardCornerRadius="@dimen/card_radius_standard"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding_standard">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/card_icon_standard"
                                android:layout_height="@dimen/card_icon_standard"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_diagnostics"
                                app:tint="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:letterSpacing="0.06"
                            android:text="@string/diagnostics_health_storage"
                            android:textAllCaps="true"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <!-- Top line: "X clips · Y used". Bound at runtime. -->
                        <TextView
                            android:id="@+id/tvStorageUsed"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/diagnostics_metric_pending"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                        <!-- Bottom line: "Z free". Bound at runtime. -->
                        <TextView
                            android:id="@+id/tvStorageFree"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/diagnostics_metric_pending"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- HEALTH 2×2 GRID — row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_gap_vertical"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Camera tile -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/card_gap_horizontal_half"
                    android:minHeight="@dimen/grid_tile_min_height"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer"
                    app:cardCornerRadius="@dimen/card_radius_standard"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding_standard">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/card_icon_standard"
                                android:layout_height="@dimen/card_icon_standard"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_camera_probe"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <View
                                android:id="@+id/viewCameraDot"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/status_dot_neutral" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:letterSpacing="0.06"
                            android:text="@string/diagnostics_health_camera"
                            android:textAllCaps="true"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvCameraValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/diagnostics_metric_pending"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Battery tile -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/card_gap_horizontal_half"
                    android:minHeight="@dimen/grid_tile_min_height"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer"
                    app:cardCornerRadius="@dimen/card_radius_standard"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding_standard">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/card_icon_standard"
                                android:layout_height="@dimen/card_icon_standard"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_battery_health"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <View
                                android:id="@+id/viewBatteryDot"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/status_dot_neutral" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:letterSpacing="0.06"
                            android:text="@string/diagnostics_health_battery"
                            android:textAllCaps="true"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvBatteryValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/diagnostics_metric_pending"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TOOLS section header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/page_padding_top"
                android:layout_marginBottom="@dimen/section_overline_bottom"
                android:letterSpacing="0.06"
                android:text="@string/diagnostics_tools_section"
                android:textAllCaps="true"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- TOOLS 2×2 GRID — row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Traffic monitor (outlined) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTraffic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/card_gap_horizontal_half"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?android:attr/colorBackground"
                    app:cardCornerRadius="@dimen/card_radius_standard"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="@dimen/card_icon_standard"
                            android:layout_height="@dimen/card_icon_standard"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_traffic_monitor"
                            app:tint="?attr/colorPrimary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTrafficLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/diagnostics_section_traffic"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:text="@string/diagnostics_traffic_subtitle"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Camera probe (outlined) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCameraProbe"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/card_gap_horizontal_half"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?android:attr/colorBackground"
                    app:cardCornerRadius="@dimen/card_radius_standard"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="@dimen/card_icon_standard"
                            android:layout_height="@dimen/card_icon_standard"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_camera_probe"
                            app:tint="?attr/colorPrimary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/diagnostics_section_camera_probe"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:text="@string/diagnostics_camera_probe_subtitle"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TOOLS 2×2 GRID — row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_gap_vertical"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- ADB Console (outlined) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAdb"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/card_gap_horizontal_half"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?android:attr/colorBackground"
                    app:cardCornerRadius="@dimen/card_radius_standard"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="@dimen/card_icon_standard"
                            android:layout_height="@dimen/card_icon_standard"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_console"
                            app:tint="?attr/colorPrimary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/diagnostics_section_adb_console"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:text="@string/diagnostics_adb_subtitle"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Battery health (outlined) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBattery"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/card_gap_horizontal_half"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?android:attr/colorBackground"
                    app:cardCornerRadius="@dimen/card_radius_standard"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="@dimen/card_icon_standard"
                            android:layout_height="@dimen/card_icon_standard"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_battery_health"
                            app:tint="?attr/colorPrimary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/diagnostics_section_battery"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:text="@string/diagnostics_battery_subtitle"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== RIGHT COLUMN — LIVE EVENT LOG CARD ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.54"
            android:layout_marginStart="@dimen/card_gap_vertical"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius_standard"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/card_padding_standard"
                android:paddingTop="@dimen/card_padding_standard"
                android:paddingBottom="@dimen/card_gap_vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/card_gap_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diagnostics_logs_card_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/diagnostics_logs_card_subtitle"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/status_dot_online" />
                </LinearLayout>

                <!-- Live logs panel — hosts LogsPanelFragment -->
                <FrameLayout
                    android:id="@+id/logsPanelContainer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
