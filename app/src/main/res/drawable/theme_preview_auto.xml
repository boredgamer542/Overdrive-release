<?xml version="1.0" encoding="utf-8"?>
<!--
  Theme preview — Auto (split light/dark gradient).

  Diagonal gradient that fades from a light grey (top-left) to a deep
  grey (bottom-right). Static colors are used here intentionally so the
  preview communicates "auto switches between light and dark" regardless
  of the head unit's current theme. Rounded 12dp inner radius nests
  inside the 18dp tile container.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#FFE8EAED"
        android:centerColor="#FF9AA0A6"
        android:endColor="#FF202124"
        android:type="linear" />
    <corners android:radius="12dp" />
</shape>
