<?xml version="1.0" encoding="utf-8"?>
<!--
  Recording library — v4 redesign (portrait).

  Goals: stop stacking 4 calendar/filter UIs on top of the list. Hero is the
  recordings grid; date and filters are slim, on-demand affordances.

  Layout:
    1. Date jump card: ◀  [icon | "Today" / formatted date | clip count | ›]  ▶
       Tap card → MaterialDatePicker. ◀/▶ → ±1 day.
    2. Filter bar: scrollable strip of currently-active filter chips (each with
       an X to clear), trailing M3 "Filter" pill that opens a bottom sheet
       hosting the actor + severity chip rows. Hidden when no filters active
       except for the trailing pill.
    3. Multi-select toolbar (unchanged).
    4. Recordings list (unchanged grid).

  IDs preserved for findViewById in RecordingLibraryFragment:
    tvSelectedDate, recyclerRecordings, emptyStateContainer, tvEmptyState,
    selectToolbar, tvSelectedCount, btnSelectAll, btnDeleteSelected,
    btnCancelSelect, filterBar (now the active-filter strip).

  Removed (and removed from Kotlin too):
    tvCurrentMonth, btnPrevMonth, btnNextMonth, btnCalendarCollapse,
    recyclerWeekStrip, btnPrevWeek, btnNextWeek, calendarBody, recyclerCalendar.

  The Source-filter chips (btnFilterAll/Normal/Sentry/Proximity) are REMOVED
  from this layout — when this fragment is embedded inside RecordingsFragment
  the parent's segmented control drives that filter, and standalone callers
  can use setSourceFilter() programmatically. This matches the existing
  ARG_HIDE_INTERNAL_FILTERS behaviour but eliminates the dead chip row.

  Actor + severity chips moved into sheet_recording_library_filters.xml.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <!-- ============================================================
         1. DATE JUMP ROW
         ============================================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevDay"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="@string/cd_previous_day"
            app:icon="@drawable/ic_chevron_left"
            app:iconSize="24dp"
            app:iconTint="?attr/colorOnSurfaceVariant"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDateJump"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/card_gap_vertical"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardElevation="0dp"
            app:cardCornerRadius="@dimen/card_radius_standard"
            app:rippleColor="?attr/colorPrimary"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_events"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true"
                    android:ellipsize="end"
                    tools:text="Today" />

                <TextView
                    android:id="@+id/tvDayClipCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/recording_lib_count_pill"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone"
                    tools:text="12 clips"
                    tools:visibility="visible" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextDay"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="@string/cd_next_day"
            app:icon="@drawable/ic_chevron_right"
            app:iconSize="24dp"
            app:iconTint="?attr/colorOnSurfaceVariant"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />
    </LinearLayout>

    <!-- ============================================================
         2. FILTER BAR (active-filter chips + "Filter" pill)
         id=filterBar preserved so existing ARG_HIDE_INTERNAL_FILTERS path
         continues to GONE the whole bar when embedded.
         ============================================================ -->
    <LinearLayout
        android:id="@+id/filterBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <HorizontalScrollView
            android:id="@+id/activeFiltersScroll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/activeFiltersGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="6dp"
                app:singleLine="true" />
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenFilters"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/cd_open_filters"
            android:text="@string/recording_lib_filter_button"
            android:textSize="13sp"
            android:paddingHorizontal="14dp"
            android:minHeight="36dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_filter_list"
            app:iconSize="18dp"
            app:iconGravity="textStart"
            app:cornerRadius="18dp"
            app:strokeColor="?attr/colorOutline" />
    </LinearLayout>

    <!-- ============================================================
         3. MULTI-SELECT TOOLBAR (unchanged behaviour)
         ============================================================ -->
    <LinearLayout
        android:id="@+id/selectToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:background="?attr/colorSurfaceVariant"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSelectedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/recording_lib_selected_count_zero" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAll"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_select_all_short"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteSelected"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_delete"
            android:textSize="12sp"
            android:textColor="@color/status_danger"
            app:icon="@drawable/ic_delete"
            app:iconTint="@color/status_danger"
            app:iconSize="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelSelect"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_cancel"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ============================================================
         4. RECORDINGS LIST (hero)
         ============================================================ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRecordings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="20dp" />

        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recording_lib_empty_emoji"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/recording_lib_no_recordings"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
