<?xml version="1.0" encoding="utf-8"?>
<!--
  Recordings page — landscape variant.

  Composition:
    Top header (full-width, identical structure to portrait):
      1. Title row: "Recordings" headline + tonal "Settings" icon-button.
      2. Counts subtitle: "X today · Y total · Z GB".
      3. M3 segmented Dashcam | Surveillance toggle group (labels carry "· N").
    Body (horizontal split):
      - Left:  RecordingLibraryFragment (list) — width 0, weight 11.
      - Right: preview pane (MaterialCardView wrapping a FrameLayout
               @id/previewContainer). The container holds an initial
               "Select a recording" placeholder; on tap of a list item
               RecordingsFragment swaps in an inline VideoPlayerFragment
               via childFragmentManager (fade in/out). Portrait keeps the
               existing global-nav full-screen launch behavior.

  Math (canvas ~960dp wide minus rail ~80dp ≈ 880dp content area):
    Outer side padding 24dp each → ~832dp usable.
    Library list  ~ 11/20 * 832 = 458dp
    Gap            16dp
    Preview pane ~  9/20 * 832 = 374dp

  IDs preserved (consumed by RecordingsFragment.kt):
    segmentedSource, segmentDashcam, segmentSurveillance,
    btnRecordingsSettings, libraryContainer, previewContainer, previewPlaceholder.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <!-- Hero header: title + summary + segmented control. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/card_gap_vertical">

        <!-- Title row: headline left, tonal Settings button right. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/recordings_title"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecordingsSettings"
                style="@style/Widget.Material3.Button.TonalButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/recordings_action_settings"
                android:text="@string/recordings_action_settings"
                android:textAllCaps="false"
                app:icon="@drawable/ic_settings"
                app:iconGravity="textStart" />
        </LinearLayout>

        <!-- Counts subtitle: populated at runtime by RecordingsFragment. -->
        <TextView
            android:id="@+id/tvRecordingsSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/recordings_summary_pending"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="12 today · 320 total · 42 GB" />

        <!-- Segmented Dashcam | Surveillance. Labels gain "· N" suffix at runtime. -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/segmentedSource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/segmentDashcam"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/recordings_segment_dashcam"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/segmentSurveillance"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/recordings_segment_surveillance"
                android:textAllCaps="false" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <!-- Two-pane body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingBottom="@dimen/page_padding_bottom"
        android:baselineAligned="false">

        <!-- LEFT: library list -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/libraryContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="11" />

        <View
            android:layout_width="@dimen/card_gap_vertical"
            android:layout_height="match_parent" />

        <!-- RIGHT: preview surface. The MaterialCardView is a fixed
             rounded-24dp surface; the inner FrameLayout @id/previewContainer
             is the swap target for the inline VideoPlayerFragment. clipChildren
             keeps the player corners rounded against the card.

             The placeholder LinearLayout is the *initial* child of
             previewContainer; when RecordingsFragment.showInlinePreview()
             commits a fragment replace into previewContainer, the placeholder
             is automatically removed. On rotation/recreate, the placeholder
             reappears because it's part of the layout. -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="9"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius_hero"
            app:cardElevation="0dp">

            <FrameLayout
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/previewPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <ImageView
                        android:layout_width="@dimen/card_icon_hero"
                        android:layout_height="@dimen/card_icon_hero"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_play_circle"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:alpha="0.6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/recordings_preview_placeholder_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/recordings_preview_placeholder_body"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
