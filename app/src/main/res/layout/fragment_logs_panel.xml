<?xml version="1.0" encoding="utf-8"?>
<!--
  SOTA Logs panel — embedded inside the Diagnostics "Live Event Log" card,
  but also reusable as a standalone fragment.

  Composition:
    HEADER : expand/collapse icon + "Logs" overline + filter spinner +
             clear-logs icon. Surface tier = ?attr/colorSurfaceContainer
             so it sits one tier above the page background, but still
             reads as part of the host card when inlined.
    LIST   : RecyclerView at ?android:attr/colorBackground.

  Preserved IDs (LogsPanelFragment.kt findViewById targets):
    logsPanelRoot, logsHeader, btnExpandCollapse, spinnerFilter,
    btnClearLogs, recyclerLogs
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/logsPanelRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurfaceContainer"
    android:orientation="vertical">

    <!-- ==================== HEADER ==================== -->
    <LinearLayout
        android:id="@+id/logsHeader"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/colorSurfaceContainer"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageButton
            android:id="@+id/btnExpandCollapse"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_expand_collapse"
            android:src="@drawable/ic_expand"
            app:tint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:letterSpacing="0.06"
            android:text="@string/logs_panel_title"
            android:textAllCaps="true"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <Spinner
            android:id="@+id/spinnerFilter"
            android:layout_width="100dp"
            android:layout_height="32dp"
            android:background="@drawable/spinner_background_glossy"
            android:popupBackground="?attr/colorSurfaceContainerHigh" />

        <ImageButton
            android:id="@+id/btnClearLogs"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_clear_logs"
            android:src="@drawable/ic_clear"
            app:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <!-- ==================== LOG LIST ==================== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLogs"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="?android:attr/colorBackground"
        android:clipToPadding="false"
        android:padding="12dp"
        android:visibility="visible" />
</LinearLayout>
