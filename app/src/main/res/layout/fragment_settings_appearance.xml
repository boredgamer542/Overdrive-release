<?xml version="1.0" encoding="utf-8"?>
<!--
  SOTA Settings → Appearance pane.

  Composition (vertical):
    HERO HEADER : "Appearance" + 1-line subtitle
    THEME CARD  : 3 tile-style preview toggles (Auto / Light / Dark) + an
                  active-state caption beneath
    LANGUAGE    : full-width card with prominent value + "X of N langs"
                  context line

  Theme tiles:
    Each tile = MaterialCardView (selectable=true). Inside the card,
    stacked rectangles show "surface tier" swatches:
      - top half  = surface
      - bottom    = surfaceContainer (with a small primary-accent pill)
    The Auto tile uses a single diagonal gradient drawable instead of
    stacked surfaces to communicate "switches between light & dark".
    The selected tile gets a 2dp colorPrimary stroke + colorSurfaceContainerHigh
    fill via theme_preview_tile_bg.xml; non-selected tiles get a 1dp
    colorOutlineVariant stroke + colorSurfaceContainer fill.

  Preserved IDs (existing Kotlin code reads these):
    themeAuto, themeLight, themeDark   → tile click targets
    themeToggleGroup                   → outer LinearLayout (was MBTG;
                                          now a host container — Kotlin
                                          rewired to per-tile click handlers)
    cardLanguage, tvLanguageValue      → language picker
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/page_padding_bottom">

        <!-- ============== HERO HEADER ============== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_appearance"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="@dimen/page_padding_top"
            android:text="@string/settings_appearance_subtitle"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- ============== THEME CARD ============== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_gap_vertical"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius_standard"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_standard">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_label"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <!-- Tile row. Equal-weight, 8dp inter-margin. The id
                     "themeToggleGroup" is preserved for backwards-compat
                     even though this is now a plain LinearLayout. -->
                <LinearLayout
                    android:id="@+id/themeToggleGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <!-- AUTO tile -->
                    <FrameLayout
                        android:id="@+id/themeAuto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/theme_preview_tile_bg"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <!-- Diagonal-gradient swatch (light → dark) -->
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="68dp"
                                android:background="@drawable/theme_preview_auto">

                                <View
                                    android:layout_width="32dp"
                                    android:layout_height="6dp"
                                    android:layout_gravity="center"
                                    android:background="@drawable/theme_preview_accent_chip" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="10dp"
                                android:text="@string/settings_theme_auto"
                                android:textAlignment="center"
                                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="?attr/colorOnSurface" />
                        </LinearLayout>
                    </FrameLayout>

                    <!-- LIGHT tile -->
                    <FrameLayout
                        android:id="@+id/themeLight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/theme_preview_tile_bg"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <!-- Two-tier light surface stack -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="68dp"
                                android:orientation="vertical">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1.2"
                                    android:background="@drawable/theme_preview_light_surface" />

                                <FrameLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/theme_preview_light_container">

                                    <View
                                        android:layout_width="32dp"
                                        android:layout_height="6dp"
                                        android:layout_gravity="center"
                                        android:background="@drawable/theme_preview_accent_chip" />
                                </FrameLayout>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="10dp"
                                android:text="@string/settings_theme_light"
                                android:textAlignment="center"
                                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="?attr/colorOnSurface" />
                        </LinearLayout>
                    </FrameLayout>

                    <!-- DARK tile -->
                    <FrameLayout
                        android:id="@+id/themeDark"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/theme_preview_tile_bg"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <!-- Two-tier dark surface stack -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="68dp"
                                android:orientation="vertical">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1.2"
                                    android:background="@drawable/theme_preview_dark_surface" />

                                <FrameLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/theme_preview_dark_container">

                                    <View
                                        android:layout_width="32dp"
                                        android:layout_height="6dp"
                                        android:layout_gravity="center"
                                        android:background="@drawable/theme_preview_accent_chip" />
                                </FrameLayout>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="10dp"
                                android:text="@string/settings_theme_dark"
                                android:textAlignment="center"
                                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="?attr/colorOnSurface" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <!-- Active-state caption — populated by Kotlin per selection. -->
                <TextView
                    android:id="@+id/tvThemeActiveCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/settings_theme_active_auto_caption"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============== LANGUAGE CARD ============== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius_standard"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding_standard"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/card_icon_service"
                    android:layout_height="@dimen/card_icon_service"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_language"
                    app:tint="?attr/colorPrimary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_language_card_title"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tvLanguageValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tvLanguageCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
