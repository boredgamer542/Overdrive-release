<?xml version="1.0" encoding="utf-8"?>
<!--
  Recording library — v4 redesign (landscape).

  Same structure as portrait but tighter vertical so the list keeps the most
  pixels in 540dp-tall landscape. Date jump and filter bar share a single row
  on landscape to claw back vertical space.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <!-- Combined header: date jump on the left, filter bar on the right. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:baselineAligned="false">

        <!-- Left: date jump (◀ card ▶) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrevDay"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cd_previous_day"
                app:icon="@drawable/ic_chevron_left"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDateJump"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardElevation="0dp"
                app:cardCornerRadius="@dimen/card_radius_standard"
                app:rippleColor="?attr/colorPrimary"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_events"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="Today" />

                    <TextView
                        android:id="@+id/tvDayClipCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="2dp"
                        android:background="@drawable/recording_lib_count_pill"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone"
                        tools:text="12 clips"
                        tools:visibility="visible" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextDay"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cd_next_day"
                app:icon="@drawable/ic_chevron_right"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </LinearLayout>

        <!-- Right: filter bar — active chips + Filter pill -->
        <LinearLayout
            android:id="@+id/filterBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp">

            <HorizontalScrollView
                android:id="@+id/activeFiltersScroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/activeFiltersGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:singleLine="true" />
            </HorizontalScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenFilters"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/cd_open_filters"
                android:text="@string/recording_lib_filter_button"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:minHeight="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_filter_list"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:cornerRadius="18dp"
                app:strokeColor="?attr/colorOutline" />
        </LinearLayout>
    </LinearLayout>

    <!-- Multi-select toolbar — unchanged behaviour, slimmer padding. -->
    <LinearLayout
        android:id="@+id/selectToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="6dp"
        android:background="?attr/colorSurfaceVariant"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSelectedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/recording_lib_selected_count_zero" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAll"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_select_all_short"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteSelected"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_delete"
            android:textSize="12sp"
            android:textColor="@color/status_danger"
            app:icon="@drawable/ic_delete"
            app:iconTint="@color/status_danger"
            app:iconSize="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelSelect"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/action_cancel"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Recordings list (hero) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRecordings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp" />

        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recording_lib_empty_emoji"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/recording_lib_no_recordings"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
