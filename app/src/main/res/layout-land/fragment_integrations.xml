<?xml version="1.0" encoding="utf-8"?>
<!--
  SOTA Integrations — landscape (1920×1080 / ~960dp × 540dp).

  Composition:
    HERO ROW   : "Integrations" title + descriptor (left) ║ neutral status pill (right)
    CARD ROW   : 3 service cards, equal weight, weight=1, 8dp inter-card gap.
                 Each card is tall (>= 360dp) and content-rich:
                   - status dot + label
                   - large 56dp icon + headline title
                   - 2–3 line description
                   - filled-tonal "Configure" button at the bottom

  Click target: ENTIRE CARD (preserves R.id.cardTelegram / cardAbrp / cardMqtt
  for IntegrationsFragment.kt findViewById). The "Configure" button is
  visual-only — its click bubbles up to the parent card via the card's
  click listener (we set duplicateParentState and the button is
  android:clickable="false" so the parent absorbs the touch).

  TODO: wire real per-service status into the dot color and label.
        For now, all dots use ?attr/colorOutline (neutral) and the label
        reads "Tap to configure".
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/page_padding_bottom">

        <!-- ================== HERO ROW ================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/page_padding_top"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/integrations_hero_title"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/integrations_hero_subtitle"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSecondaryContainer"
                app:cardCornerRadius="999dp"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="@string/integrations_status_unknown"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="?attr/colorOnSecondaryContainer" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ================== CARD ROW ================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- ===== TELEGRAM CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTelegram"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/card_gap_horizontal_half"
                android:minHeight="360dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/card_radius_hero"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_hero">

                    <!-- Status row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/dotTelegram"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/status_dot_neutral" />

                        <TextView
                            android:id="@+id/tvTelegramStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:letterSpacing="0.06"
                            android:text="@string/integrations_status_unknown"
                            android:textAllCaps="true"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <!-- Title + icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/nav_page_telegram"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="@dimen/card_icon_hero"
                            android:layout_height="@dimen/card_icon_hero"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_telegram"
                            app:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <!-- Description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/integrations_telegram_desc"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <!-- Spacer pushes the button to the bottom -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:minHeight="20dp" />

                    <!-- Configure button — visual only; parent card absorbs the click -->
                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:clickable="false"
                        android:duplicateParentState="true"
                        android:focusable="false"
                        android:text="@string/integrations_configure_button"
                        app:cornerRadius="14dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== ABRP CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAbrp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="@dimen/card_gap_horizontal_half"
                android:minHeight="360dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/card_radius_hero"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_hero">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/dotAbrp"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/status_dot_neutral" />

                        <TextView
                            android:id="@+id/tvAbrpStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:letterSpacing="0.06"
                            android:text="@string/integrations_status_unknown"
                            android:textAllCaps="true"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/nav_page_abrp"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="@dimen/card_icon_hero"
                            android:layout_height="@dimen/card_icon_hero"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_route"
                            app:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/integrations_abrp_desc"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:minHeight="20dp" />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:clickable="false"
                        android:duplicateParentState="true"
                        android:focusable="false"
                        android:text="@string/integrations_configure_button"
                        app:cornerRadius="14dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== MQTT CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMqtt"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/card_gap_horizontal_half"
                android:minHeight="360dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/card_radius_hero"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_hero">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/dotMqtt"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/status_dot_neutral" />

                        <TextView
                            android:id="@+id/tvMqttStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:letterSpacing="0.06"
                            android:text="@string/integrations_status_unknown"
                            android:textAllCaps="true"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/nav_page_mqtt"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="@dimen/card_icon_hero"
                            android:layout_height="@dimen/card_icon_hero"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_mqtt"
                            app:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/integrations_mqtt_desc"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:minHeight="20dp" />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:clickable="false"
                        android:duplicateParentState="true"
                        android:focusable="false"
                        android:text="@string/integrations_configure_button"
                        app:cornerRadius="14dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
